generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../db/audit.db"
}

model AuditIssue {
  id            String   @id @default(cuid())
  issueId       String   @unique
  severity      String
  source        String
  file          String
  line          Int      @default(0)
  category      String
  title         String
  description   String
  recommendation String
  status        String   @default("open")
  priority      Int      @default(0)
  effort        String   @default("")
  impact        String   @default("")
  assignee      String   @default("")
  notes         String   @default("")
  fixedAt       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  logs AuditLog[]
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  issueId   String
  oldStatus String?
  newStatus String?
  details   String   @default("")
  createdAt DateTime @default(now())

  issue AuditIssue @relation(fields: [issueId], references: [issueId])
}